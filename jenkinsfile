pipeline {
    agent any 
    
    tools {
        nodejs 'node20'  // configure this in jenkins gloabl tools
    }

    environment {
        SCANNER_HOME= tool 'sonar-scanner' // confgiure sonarqube scanner in global tool
        DOCKER_IMAGE= "sumeruc123/nodejs:latest"
        GIT_CREDENTIAL="git cred"
    }

    stages{
        stage(' 1. Clean workspace'){
            steps {
                cleanWs()
            }
        }

        stage('2. Git checkout'){
            steps{
                git url: "https://github.com/sumeruc123/myapp:latest.git"
                    credential: "${GIT_CREDENTIAL}"
                    branch: "main"
            }
        }

        stage('3. SonarQube anaylsis'){
            steps{
                withSonarQUbeEnv('sonar-server'){
                    sh """
                    $SCANNER_HOME/bin/sonar-scanner
                    -Dosnar.projectName=myapp
                    -Dsonar.projectKey=myapp
                    -Dsonar.sources=.
                    """
                }
            }
        }

        stage('4. Quality gate anaylsis'){
            steps{
                waitForQualityGate abortpipeline: false
            }
        }

        stage('5. install dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('6. Docker build & push'){
            steps{
                withDockerRegistry(credentialId: 'docker-cred', toolName: 'docker'){
                    sh 'docker build -t ${DOCKER_IMAGE} .'
                    sh 'docker push ${DOCKER_IMAGE}'
                }
            }
        }
    }
}